#!/usr/bin/env bash
#
# DESCRIPTION
#   Generate a keychain-migration script for a new Mac and place it on the
#   clipboard. The generated script re-creates each secret in the new
#   machine's Login Keychain via `security add-generic-password`.
#
#   NOTE: This script is specific to my setup. The service list mirrors the
#   secrets inventory in dotfiles (.claude/rules/secrets.md); update both
#   together.
#
#   Secret values live only in the clipboard, never on disk or in terminal
#   output. With Universal Clipboard (same iCloud account, Macs nearby),
#   the payload is available on the new Mac immediately. On the new Mac,
#   run `pbpaste | bash` rather than pasting into the prompt, so values
#   never hit the terminal scrollback or shell history. The generated
#   script clears the new Mac's clipboard when it finishes; clear this
#   machine's clipboard afterward with `pbcopy < /dev/null`.
#
#   WARNING: Clipboard managers on either Mac will capture the payload.
#   Pause or purge them before running.
#
# USAGE
#   migrate-keychain-secrets [OPTIONS]
#
# ARGUMENTS
#   None
#
# OPTIONS
#   -h, --help    Show this help message
#
# EXAMPLES
#   migrate-keychain-secrets

set -euo pipefail

# Colors
red='\033[0;31m'
reset='\033[0m'

ACCOUNT='function-health'

SERVICES=(
  conductorone-client-id
  conductorone-client-secret
  statsig-console
  stripe-test
  stripe-prod
  stripe-prod-webhooks
  dx-api
  datadog-app
  fh-github-token
)

# Print usage information.
function usage() {
  echo "usage: migrate-keychain-secrets [OPTIONS]"
  echo ""
  echo "Options:"
  echo "  -h, --help    Show this help message"
  echo ""
}

# Parse command line arguments.
while [[ $# -gt 0 ]]; do
  case $1 in
    -h | --help)
      usage
      exit 0
      ;;
    -*)
      echo -e "${red}Unknown option: $1${reset}" >&2
      usage
      exit 1
      ;;
    *)
      echo -e "${red}Unknown argument: $1${reset}" >&2
      usage
      exit 1
      ;;
  esac
done

{
  echo 'set -euo pipefail'
  for s in "${SERVICES[@]}"; do
    v=$(security find-generic-password -s "${s}" -a "${ACCOUNT}" -w)
    printf 'security add-generic-password -s %q -a %q -U -w %q\n' \
      "${s}" "${ACCOUNT}" "${v}"
  done
  printf 'echo "Imported %s entries. Clearing clipboard."\n' "${#SERVICES[@]}"
  echo 'pbcopy < /dev/null'
} | pbcopy

echo "Migration script for ${#SERVICES[@]} entries is on the clipboard."
echo "On the new Mac, run: pbpaste | bash"
echo "Afterward, clear this Mac's clipboard: pbcopy < /dev/null"
