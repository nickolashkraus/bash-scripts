#!/usr/bin/env bash
#
# DESCRIPTION
#   Generate a kubeconfig file for all GKE clusters.
#
#   NOTE: This script is specific to Function Health.
#
#   The cluster list, server endpoints, and CA certificate data are not
#   committed to the dotfiles repository (which is public). Run this script
#   to materialize $HOME/.kube/function.yaml on first install or whenever
#   the cluster set changes.
#
#   Requires `gcloud` (authenticated against Function Health) and `jq`.
#
# USAGE
#   generate-fh-kubeconfig [OPTIONS]
#
# ARGUMENTS
#   None
#
# OPTIONS
#   -o, --output FILE    Path to the output file
#   -h, --help           Show this help message
#
# EXAMPLES
#   generate-fh-kubeconfig --output ~/.kube/function.yaml

# Colors
red='\033[0;31m'
reset='\033[0m'

# Print usage information.
function usage() {
  echo "usage: generate-fh-kubeconfig [OPTIONS]"
  echo ""
  echo "Options:"
  echo "  -o, --output FILE    Path to the output file"
  echo "  -h, --help           Show this help message"
  echo ""
}

output_file=""

# Parse command line arguments.
while [[ $# -gt 0 ]]; do
  case $1 in
    -o | --output)
      output_file=$2
      shift 2
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage
      exit 1
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage
      exit 1
      ;;
  esac
done

# Check if 'output_file' is set. If not, exit with non-zero error code.
if [ -z "${output_file}" ]; then
  echo -e "${red}ERROR: Specify an output file (ex. ~/.kube/function.yaml).${reset}" >&2
  usage
  exit 1
fi

if ! [ -x "$(command -v gcloud)" ]; then
  echo -e "${red}ERROR: gcloud CLI is not installed.${reset}" >&2
  exit 1
fi

if ! [ -x "$(command -v jq)" ]; then
  echo -e "${red}ERROR: jq is not installed.${reset}" >&2
  exit 1
fi

cat <<EOT >"${output_file}"
###############################################################################
# Function Health kubeconfig File
#
# DESCRIPTION
#   Use kubeconfig files to organize information about clusters, users,
#   namespaces, and authentication mechanisms. The kubectl command-line tool
#   uses kubeconfig files to find the information it needs to choose a cluster
#   and communicate with the API server of a cluster. See:
#   https://kubernetes.io/docs/concepts/configuration/organize-cluster-access-kubeconfig/
#
#   /!\\ WARNING /!\\
#   File generated by generate-fh-kubeconfig. DO NOT EDIT.
#
#     \`\`\`
#     \$ generate-fh-kubeconfig --output \$HOME/.kube/function.yaml
#     \`\`\`
#
#   Access to these clusters is gated by ConductorOne entitlements
#   ("Kubernetes Engine Admin" on the corresponding GCP project). Request
#   short-lived access via \`cone get\`.
###############################################################################

apiVersion: v1
kind: Config
preferences: {}

EOT

CLUSTERS=(
  function-health-dev-env:us-central1:gke-cluster-common-dev
  function-health-prod-env:us-central1:autopilot-pro-admin-app-cluster-1
  function-health-prod-env:us-central1:gke-cluster-common-prod
  function-health-sandbox-env:us-central1:gke-cluster-common-sandbox
)

cat <<EOT >>"${output_file}"
clusters:
EOT

for i in "${CLUSTERS[@]}"; do
  IFS=':' read -ra ARRAY <<<"${i}"
  project="${ARRAY[0]}"
  region="${ARRAY[1]}"
  name="${ARRAY[2]}"
  output=$(gcloud container clusters describe "${name}" \
    --project "${project}" --region "${region}" --format=json)
  endpoint=$(jq -r '.endpoint' <<<"${output}")
  ca_data=$(jq -r '.masterAuth.clusterCaCertificate' <<<"${output}")
  cat <<EOT >>"${output_file}"
  - cluster:
      certificate-authority-data: ${ca_data}
      server: https://${endpoint}
    name: gke_${project}_${region}_${name}
EOT
  printf '.'
done
echo ''

cat <<EOT >>"${output_file}"
contexts:
EOT

for i in "${CLUSTERS[@]}"; do
  IFS=':' read -ra ARRAY <<<"${i}"
  project="${ARRAY[0]}"
  region="${ARRAY[1]}"
  name="${ARRAY[2]}"
  full="gke_${project}_${region}_${name}"
  cat <<EOT >>"${output_file}"
  - context:
      cluster: ${full}
      user: ${full}
    name: ${full}
EOT
done

# Default to the dev common cluster.
cat <<EOT >>"${output_file}"
current-context: gke_function-health-dev-env_us-central1_gke-cluster-common-dev
users:
EOT

for i in "${CLUSTERS[@]}"; do
  IFS=':' read -ra ARRAY <<<"${i}"
  project="${ARRAY[0]}"
  region="${ARRAY[1]}"
  name="${ARRAY[2]}"
  full="gke_${project}_${region}_${name}"
  cat <<EOT >>"${output_file}"
  - name: ${full}
    user:
      exec:
        apiVersion: client.authentication.k8s.io/v1beta1
        command: gke-gcloud-auth-plugin
        installHint:
          Install gke-gcloud-auth-plugin for use with kubectl by following
          https://cloud.google.com/kubernetes-engine/docs/how-to/cluster-access-for-kubectl#install_plugin
        provideClusterInfo: true
EOT
done
